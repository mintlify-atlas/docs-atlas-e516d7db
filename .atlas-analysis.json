  "keyFeatures": [
    "JWT authentication with access and refresh tokens",
    "Role-Based Access Control (RBAC) with Admin and User roles",
    "Full CRUD for tasks with status, priority, and due dates",
    "Tag system for organizing tasks with custom colors",
    "Advanced filtering by status, priority, tags, dates, and search",
    "Server-side pagination and customizable sorting",
    "Data export to CSV and JSON formats",
    "Rate limiting with Flask-Limiter",
    "Interactive Swagger/OpenAPI documentation",
    "Azure App Service deployment with Azure SQL Database"
  ],
